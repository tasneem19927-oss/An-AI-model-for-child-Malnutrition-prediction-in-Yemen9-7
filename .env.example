# =========================================================================
# Yemen Child Malnutrition CDS Platform - Unified Production Environment Template
# =========================================================================

# --- 1. CORE API KEY CONFIGURATIONS ---
# Required for offline/online Gemini LLM-driven Clinical Summary & Evidence grounding
GEMINI_API_KEY="AI_STUDIO_INJECTED_OR_YOUR_SECURE_API_KEY"

# --- 2. MULTI-TIER REVERSE PROXY & HOST URL ---
# Base domain where the unified platform is serving (Self-Referential Links & CORS)
APP_URL="https://malnutrition-cds.gov.ye"

# --- 3. NODE.JS WEB & EXPRESS FRONTEND SERVER ---
# External Port for the Vite Single Page App (SPA) and Express Gateway
PORT=3000
NODE_ENV=production

# --- 4. PYTHON FASTAPI BACKEND CONFIGURATIONS ---
# Microservices endpoint for XGBoost classifiers, FAISS indexes, and BioMobileBERT
BACKEND_API_URL="http://localhost:8000"

# --- 5. POSTGRESQL DURABLE STORAGE SCHEMA ---
# Connection credentials mapping FastAPI to Postgres relational containers
DATABASE_URL="postgresql://postgres:postgres_secure_pass_123@localhost:5432/malnutrition_db"
POSTGRES_PASSWORD="postgres_secure_pass_123"

# --- 6. JWT SECURITY & CRYPTO KEYSETS ---
# Secret seed utilized for encoding RBAC access tokens securely on device/cloud
JWT_SECRET_KEY="generate_secure_random_key_using_openssl_rand_hex_32"
